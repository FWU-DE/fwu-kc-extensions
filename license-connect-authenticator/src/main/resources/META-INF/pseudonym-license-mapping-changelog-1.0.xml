<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet author="lea.haas@intension.de" id="pseudonym-licence-mapping-changelog-1.0">

        <createTable tableName="HMAC_PSEUDONYM_LICENCE">
            <column name="ID" type="BIGINT">
                <constraints nullable="false" />
            </column>
            <column name="HMAC_PSEUDONYM" type="VARCHAR(256)">
                <constraints nullable="false" />
            </column>
            <column name="LICENCE" type="CLOB">
                <constraints nullable="false" />
            </column>
        </createTable>

        <addAutoIncrement tableName="HMAC_PSEUDONYM_LICENCE" columnName="ID" columnDataType="BIGINT" incrementBy="1" startWith="1" />

    </changeSet>

</databaseChangeLog>
